{
  "name": "@survey-tracker/frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Frontend dashboard para monitoreo de encuestas",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx",
