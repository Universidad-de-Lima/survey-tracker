    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@survey-tracker/eslint-config": "workspace:*",
    "@survey-tracker/tsconfig": "workspace:*",
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.0",
    "tailwindcss": "^4.1.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^15.0.0",
    "eslint": "^8.57.0",
    "jsdom": "^24.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.6.0",
    "serve": "^14.2.0"
